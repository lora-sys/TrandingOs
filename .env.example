# Trading Pi — Local Environment
# Copy to `.env` and fill in. All keys optional except OPENAI_API_KEY for live model calls.

# === LLM provider (required for live chat) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.longcat.chat/openai
OPENAI_MODEL=LongCat-2.0
# Enable reasoning for reasoning-capable models (LongCat, o1, o3, etc.)
OPENAI_REASONING=false

# === Agent runtime ===
# Thinking budget: off | minimal | low | medium | high | xhigh
TRADING_PI_THINKING_LEVEL=medium

# === Server ===
TRADING_PI_API_PORT=8787
TRADING_PI_WEB_PORT=5173
TRADING_PI_DATA_DIR=.trading-pi
TRADING_PI_TRADING_MODE=paper   # mock | paper | live_guarded
TRADING_PI_DEFAULT_EXCHANGE=binance
TRADING_PI_EXCHANGE_FALLBACKS=okx,bybit,coinbase,kraken

# === Optional integrations ===
EXA_API_KEY=
TAVILY_API_KEY=
JINA_API_KEY=
COINMARKETCAP_API_KEY=
FRED_API_KEY=
COINMARKETCAL_API_KEY=
AIO_SANDBOX_BASE_URL=

# === Telemetry ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=