# OpenAI-compatible AI configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# === Data Sources (P0 — Required for Full MVP) ===
# Web search & AI-native search (Deep Research, Alpha Radar, News)
EXA_API_KEY=
# Web page reading & scraping (Deep Research read pages, Research)
JINA_API_KEY=
# Alternative web search (backup)
TAVILY_API_KEY=

# === Premium Features (P1 — Enhances Deep Research Quality) ===
# For DeepResearch model via OpenRouter: alibaba/tongyi-deepresearch-30b-a3b
OPENROUTER_API_KEY=
# Google Search API (alternative to Exa)
SERPER_DEV_KEY=
# Enhanced crypto data (supplements CoinGecko)
COINMARKETCAP_API_KEY=
# Alibaba DashScope file parsing (alternative to Jina)
DASHSCOPE_API_KEY=

# === Event Feed (P0 — Dashboard Today's Reminders) ===
# Macro economic events: FOMC, CPI, Non-Farm Payrolls, GDP, interest rates
TRADINGECONOMICS_API_KEY=
# Crypto-native events: token listings, unlocks, airdrops, upgrades, exchange listings
COINMARKETCAL_API_KEY=

# === Optional API Keys (P2) ===
# Polymarket CLOB API (optional, Gamma API is free — no auth needed)
POLYMARKET_API_KEY=
# Reddit OAuth (optional, public JSON API works without auth)
REDDIT_CLIENT_ID=

# === Academic Search (Free — for Deep Research Agent) ===
# Semantic Scholar API key (optional — free without key: 1000 req/sec shared; with key: 1 req/sec dedicated)
SEMANTIC_SCHOLAR_API_KEY=
# Crossref (no key needed, but email in User-Agent header recommended)
CROSSREF_MAILTO=
# OpenAlex (no key needed, fully open)
OPENALEX_EMAIL=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Local app
TRADING_PI_DATA_DIR=.trading-pi
TRADING_PI_API_PORT=8787
TRADING_PI_WEB_PORT=5173
TRADING_PI_DEFAULT_EXCHANGE=binance
TRADING_PI_EXCHANGE_FALLBACKS=okx,bybit,coinbase,kraken
TRADING_PI_TRADING_MODE=paper

# OS integrations
# AIO Sandbox (Phase 2 — browser fallback scraper, not needed in MVP)
AIO_SANDBOX_BASE_URL=http://localhost:8080
