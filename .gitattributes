# Normalize line endings on checkout / commit

*               text=auto eol=lf

# Source code
*.ts            text eol=lf
*.tsx           text eol=lf
*.js            text eol=lf
*.jsx           text eol=lf
*.mjs           text eol=lf
*.cjs           text eol=lf
*.json          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf

# Markdown — keep trailing whitespace (used for hard line breaks)
*.md            text eol=lf

# Shell + scripts
*.sh            text eol=lf
bash            text eol=lf

# Binary
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.woff          binary
*.woff2         binary
*.ttf           binary
*.pdf           binary
