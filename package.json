{
  "name": "trading-pi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server -w @trading-pi/web\" \"npm run dev -w @trading-pi/web\"",
    "dev:web": "npm run dev -w @trading-pi/web",
    "build": "npm run build --workspaces",
    "check": "tsc -b",
    "test": "vitest run",
    "test:core": "vitest run packages/core",
    "test:web": "vitest run apps/web",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "24.12.4",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "9.2.1",
    "playwright": "^1.60.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "5.9.3",
    "vite": "7.2.7",
    "vitest": "3.2.4"
  },
  "overrides": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "dependencies": {
    "@tanstack/react-start": "^1.168.25",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.2.0",
    "recharts": "^3.8.1",
    "socks-proxy-agent": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "vinxi": "^0.5.11",
    "ws": "^8.21.0"
  }
}
